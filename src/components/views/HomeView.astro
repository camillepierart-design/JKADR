---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import TeamCard from '@components/TeamCard.astro';
import { site } from '@data/site';
import { getLangFromUrl, localize, useTranslations } from '../../i18n';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const team = (await getCollection('team')).sort((a, b) => a.data.order - b.data.order);

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'LegalService',
    name: site.fullName,
    description: site.description,
    url: site.url,
    email: site.email,
    telephone: site.phone,
    vatID: site.vat,
    areaServed: 'Worldwide',
    address: {
      '@type': 'PostalAddress',
      streetAddress: site.address.street,
      addressLocality: 'Brussels',
      postalCode: '1160',
      addressCountry: 'BE',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: 'Jan Kleinheisterkamp',
    honorificPrefix: 'Prof. Dr.',
    jobTitle: 'International Arbitrator & Mediator',
    url: `${site.url}/team/jan-kleinheisterkamp`,
    email: site.email,
    address: {
      '@type': 'PostalAddress',
      streetAddress: site.address.street,
      addressLocality: 'Brussels',
      addressCountry: 'BE',
    },
  },
];

const facts: [string, string][] = [
  [t('home.factSince'), '2006'],
  [t('home.factLangs'), 'EN · ES · PT · DE · FR'],
  [t('home.factIcsid'), t('home.factIcsidVal')],
];
---

<BaseLayout title={site.name} jsonLd={jsonLd} headerVariant="overlay">
  <!-- Hero -->
  <section class="relative h-[92vh] min-h-[38rem] w-full overflow-hidden bg-night">
    <picture>
      <source media="(max-width: 767px)" srcset="/images/chateau-tall.jpg" />
      <img
        src="/images/chateau-hero.jpg"
        alt="Château de la Solitude, Brussels — the office of Prof. Dr. Jan Kleinheisterkamp"
        class="absolute inset-0 h-full w-full object-cover object-center [filter:saturate(0.85)_contrast(0.97)]"
        loading="eager"
        fetchpriority="high"
      />
    </picture>
    <div class="absolute inset-0 bg-gradient-to-t from-night/85 via-night/35 to-night/30"></div>
    <div class="shell absolute inset-x-0 bottom-0 pb-16 lg:pb-24">
      <p class="font-sans text-meta uppercase tracking-eyebrow text-paper/80">{t('home.heroEyebrow')}</p>
      <h1 class="mt-6 max-w-4xl text-display-xl text-paper">Prof.&nbsp;Dr.&nbsp;Jan Kleinheisterkamp</h1>
      <div class="mt-8 h-px w-24 bg-bordeaux-light/70"></div>
      <p class="mt-8 font-display text-[1.4rem] italic text-paper/90 sm:text-2xl">{t('site.tagline')}</p>
    </div>
  </section>

  <!-- 01 — About -->
  <section class="shell py-section lg:py-section-lg">
    <div class="grid gap-y-12 lg:grid-cols-12 lg:gap-x-16">
      <div class="lg:col-span-4">
        <p class="eyebrow"><span class="eyebrow-num">01</span> {t('home.aboutEyebrow')}</p>
      </div>
      <div class="reveal lg:col-span-8">
        <h2 class="max-w-measure-lg text-display-md text-ink">{t('home.aboutHeading')}</h2>
        <div class="mt-10 max-w-measure space-y-6 text-body-lg leading-relaxed text-ink-muted">
          <p>{t('home.aboutBody')}</p>
          <p class="font-display text-[1.35rem] italic leading-snug text-ink">{t('home.onlyArb')}</p>
        </div>
        <a href={localize(lang, '/about')} class="mt-10 inline-block">
          <span class="link-quiet font-sans text-meta uppercase tracking-eyebrow">{t('cta.readMore')}</span>
        </a>

        <dl class="mt-16 grid gap-px border-t border-ink-line sm:grid-cols-3">
          {
            facts.map(([k, v]) => (
              <div class="border-b border-ink-line py-6 sm:border-b-0 sm:pr-6">
                <dt class="font-sans text-meta uppercase tracking-eyebrow text-ink-soft">{k}</dt>
                <dd class="mt-3 font-display text-xl text-ink">{v}</dd>
              </div>
            ))
          }
        </dl>
      </div>
    </div>
  </section>

  <!-- 02 — Practice -->
  <section class="border-y border-ink-line bg-paper-dim">
    <div class="shell py-section lg:py-section-lg">
      <div class="grid gap-y-12 lg:grid-cols-12 lg:gap-x-16">
        <div class="lg:col-span-4">
          <p class="eyebrow"><span class="eyebrow-num">02</span> {t('home.practiceEyebrow')}</p>
        </div>
        <div class="lg:col-span-8">
          <div class="grid gap-12 md:grid-cols-2 md:gap-16">
            <div class="reveal">
              <h3 class="font-display text-display-sm text-ink">{t('home.arbHeading')}</h3>
              <p class="mt-5 max-w-measure text-body leading-relaxed text-ink-muted">{t('home.arbBody')}</p>
              <a href={localize(lang, '/practice')} class="mt-7 inline-block">
                <span class="link-quiet font-sans text-meta uppercase tracking-eyebrow">{t('cta.thePractice')}</span>
              </a>
            </div>
            <div class="reveal md:border-l md:border-ink-line md:pl-16">
              <h3 class="font-display text-display-sm text-ink">{t('home.medHeading')}</h3>
              <p class="mt-5 max-w-measure text-body leading-relaxed text-ink-muted">{t('home.medBody')}</p>
              <a href={localize(lang, '/practice')} class="mt-7 inline-block">
                <span class="link-quiet font-sans text-meta uppercase tracking-eyebrow">{t('cta.thePractice')}</span>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 03 — Team (dark band, matching the studio portraits) -->
  <section class="bg-night">
    <div class="shell py-section lg:py-section-lg">
      <div class="grid gap-y-12 lg:grid-cols-12 lg:gap-x-16">
        <div class="lg:col-span-4">
          <p class="flex items-center gap-3 font-sans text-meta uppercase tracking-eyebrow text-night-soft">
            <span class="tabular-nums text-bordeaux-light">03</span>
            <span class="h-px w-10 bg-night-line"></span>
            <span>{t('home.teamEyebrow')}</span>
          </p>
          <h2 class="mt-8 max-w-xs text-display-md text-paper">{t('home.teamHeading')}</h2>
          <a href={localize(lang, '/team')} class="group mt-8 inline-flex items-center gap-2">
            <span
              class="font-sans text-meta uppercase tracking-eyebrow text-night-soft transition-colors duration-300 group-hover:text-paper"
              >{t('cta.allProfiles')}</span
            >
            <span aria-hidden="true" class="text-bordeaux-light">&rarr;</span>
          </a>
        </div>
        <div class="lg:col-span-8">
          <div class="grid gap-x-8 gap-y-14 sm:grid-cols-2">
            {
              team.map((m, i) => (
                <TeamCard
                  name={m.data.name.replace('Prof. Dr. ', '')}
                  role={m.data.role}
                  portrait={m.data.portrait}
                  href={localize(lang, `/team/${m.slug}`)}
                  index={String(i + 1).padStart(2, '0')}
                  dark
                />
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact prompt -->
  <section class="border-t border-ink-line bg-paper-dim">
    <div class="shell py-section lg:py-section-lg">
      <div class="reveal grid gap-y-10 lg:grid-cols-12 lg:gap-x-16">
        <div class="lg:col-span-7">
          <p class="eyebrow"><span class="eyebrow-num">—</span> {t('home.contactEyebrow')}</p>
          <h2 class="mt-8 max-w-measure-lg text-display-lg text-ink">{t('home.contactHeading')}</h2>
        </div>
        <div class="lg:col-span-5 lg:pt-2">
          <address class="space-y-1 text-body not-italic text-ink-muted">
            <span class="block">{site.address.building}</span>
            <span class="block">{site.address.street}</span>
            <span class="block">{site.address.city} — {site.address.country}</span>
          </address>
          <p class="mt-5 text-body">
            <a class="link-quiet" href={`mailto:${site.email}`}>{site.email}</a>
          </p>
          <a href={localize(lang, '/contact')} class="btn mt-9">{t('cta.getInTouch')}</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
