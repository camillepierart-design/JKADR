---
import BaseLayout from '@layouts/BaseLayout.astro';

const swatches = [
  ['Paper', 'bg-paper', '#FAF8F4'],
  ['Paper / dim', 'bg-paper-dim', '#F1EDE3'],
  ['Paper / deep', 'bg-paper-deep', '#EAE4D7'],
  ['Ink', 'bg-ink', '#1A1A1A'],
  ['Ink / muted', 'bg-ink-muted', '#46433E'],
  ['Ink / soft', 'bg-ink-soft', '#6F6A60'],
  ['Ink / line', 'bg-ink-line', '#DCD6C9'],
  ['Bordeaux', 'bg-bordeaux', '#6B1F1F'],
  ['Bordeaux / hover', 'bg-bordeaux-hover', '#511717'],
  ['Night', 'bg-night', '#171513'],
];
const types = [
  ['display-xl', 'text-display-xl', 'Experience, efficiency'],
  ['display-lg', 'text-display-lg', 'Arbitration & Mediation'],
  ['display-md', 'text-display-md', 'A boutique practice'],
  ['display-sm', 'text-display-sm', 'Section heading'],
  ['lede', 'text-lede text-ink-muted', 'Introductory lede paragraph for a page.'],
  ['body', 'text-body text-ink-muted', 'Body copy — the workhorse reading size at 1.0625rem / 1.7.'],
  ['meta', 'text-meta uppercase tracking-eyebrow text-ink-soft', 'Meta · eyebrow · caps'],
];
---

<BaseLayout title="Styleguide" noindex={true}>
  <section class="shell pb-16 pt-28 lg:pt-40">
    <p class="eyebrow"><span class="eyebrow-num">∗</span> Internal</p>
    <h1 class="mt-6 text-display-xl text-ink">Styleguide</h1>
    <p class="mt-6 max-w-measure text-lede text-ink-muted">
      Component & token reference for kleinheisterkamp.com. Hidden route, noindex.
    </p>
  </section>

  <section class="shell border-t border-ink-line py-section">
    <p class="eyebrow"><span class="eyebrow-num">01</span> Typography — Fraunces &amp; Inter</p>
    <div class="mt-12 space-y-8">
      {
        types.map(([label, cls, sample]) => (
          <div class="grid items-baseline gap-2 border-b border-ink-line pb-8 sm:grid-cols-[10rem_1fr]">
            <span class="font-sans text-meta uppercase tracking-eyebrow text-ink-soft">{label}</span>
            <span class={cls}>{sample}</span>
          </div>
        ))
      }
      <p class="max-w-measure-lg font-display text-2xl italic text-ink">
        Fraunces italic — used for the tagline and pull quotes.
      </p>
    </div>
  </section>

  <section class="shell border-t border-ink-line py-section">
    <p class="eyebrow"><span class="eyebrow-num">02</span> Colour</p>
    <div class="mt-12 grid gap-6 sm:grid-cols-3 lg:grid-cols-5">
      {
        swatches.map(([name, bg, hex]) => (
          <div>
            <div class={`h-24 w-full border border-ink-line ${bg}`} />
            <p class="mt-3 font-sans text-sm text-ink">{name}</p>
            <p class="font-sans text-meta text-ink-soft">{hex}</p>
          </div>
        ))
      }
    </div>
  </section>

  <section class="shell border-t border-ink-line py-section">
    <p class="eyebrow"><span class="eyebrow-num">03</span> Actions &amp; links</p>
    <div class="mt-12 flex flex-wrap items-center gap-8">
      <a href="#" class="btn">Primary button</a>
      <span class="bg-night px-7 py-3"><a href="#" class="btn-light">Light button</a></span>
      <a href="#"><span class="link-quiet font-sans text-meta uppercase tracking-eyebrow">Quiet link</span></a>
      <a href="#" class="link-quiet text-body text-ink">Inline body link</a>
    </div>
  </section>

  <section class="shell border-t border-ink-line py-section">
    <p class="eyebrow"><span class="eyebrow-num">04</span> Prose — editorial</p>
    <div class="prose prose-editorial mt-12">
      <p>
        Standard editorial body copy at the reading measure. He has extensive
        experience as a sole arbitrator, presiding arbitrator and co-arbitrator
        in ICC, LCIA and UNCITRAL proceedings.
      </p>
      <blockquote>
        The mediator invites the parties to stop tugging, to pause and re-focus
        on their respective interests.
      </blockquote>
      <h2>A second-level heading</h2>
      <p>
        Body following a heading, with an <a href="#">inline link</a> shown in
        bordeaux with an underline-reveal on hover.
      </p>
    </div>
  </section>
</BaseLayout>
